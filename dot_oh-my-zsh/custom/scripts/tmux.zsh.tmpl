tmux-start() {
  tmux new -ADs Sasaya
}

{{ if eq .chezmoi.hostname "mini" -}}
tmux-init() {
  golden_path=~/Coding/UniverseTech/api
  live_path=~/Coding/UniverseTech/live-api
  hyperf_path=~/Coding/UniverseTech/hyperf-api
  openim_path=~/Coding/UniverseTech/openim/openim-api

  tmux \
    rename-window -t 0 k9s \; \
    new-window -n golden -c $golden_path \; split-window -t golden -l 10 -c $golden_path \; select-pane -t 0 \; \
    new-window -n openim -c $openim_path \; split-window -t openim -l 10 -c $openim_path \; select-pane -t 0 \; \
    new-window -n live -c $live_path \; split-window -t live -l 10 -c $live_path \; select-pane -t 0 \; \
    new-window -n hyperf -c $hyperf_path \; split-window -t hyperf -l 10 -c $hyperf_path \; select-pane -t 0 \; \
    select-window -t k9s
}
{{ end -}}
